{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "start-server",
            "type": "shell",
            "command": "bundle exec jekyll serve --host 0.0.0.0 --livereload --watch --incremental --verbose --destination /tmp/_site --disable-disk-cache --force_polling --profile",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "isBackground": true,
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "dedicated"
            }
        }
    ]
}